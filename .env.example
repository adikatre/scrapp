# Google Maps / Places (required for /locations page)

# Server-side: Places API Text Search + Place Details (keep secret)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Client-side: Maps JavaScript API for interactive map tiles
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Backend URL (existing)
NEXT_PRIVATE_BACKEND_URL=http://localhost:5000

# Shared secret sent to the backend as `Authorization: Bearer <key>`.
# Must match BACKEND_API_KEY on the Railway backend exactly.
BACKEND_API_KEY=
